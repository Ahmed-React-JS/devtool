#!/bin/bash

# ============================================================
#  Ahmed Dev Toolkit v1.0
#  macOS Developer Maintenance CLI
# ============================================================

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# Log file
LOG_FILE="$HOME/.devtool-log.txt"

# ---- Helpers ----

free_space() {
  df -h / | awk 'NR==2 {print $4}'
}

disk_used() {
  df -h / | awk 'NR==2 {print $3}'
}

log() {
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
}

header() {
  clear
  echo ""
  echo -e "${BOLD}${CYAN}╔══════════════════════════════════════╗${RESET}"
  echo -e "${BOLD}${CYAN}║       Ahmed Dev Toolkit v1.0         ║${RESET}"
  echo -e "${BOLD}${CYAN}╚══════════════════════════════════════╝${RESET}"
  echo ""
}

section() {
  echo ""
  echo -e "${BOLD}${BLUE}▶ $1${RESET}"
  echo -e "${DIM}──────────────────────────────────────${RESET}"
}

success() {
  echo -e "  ${GREEN}✓${RESET} $1"
}

warn() {
  echo -e "  ${YELLOW}⚠${RESET}  $1"
}

info() {
  echo -e "  ${CYAN}→${RESET} $1"
}

confirm() {
  echo ""
  echo -e "  ${YELLOW}$1 [y/N]${RESET} \c"
  read -r response
  [[ "$response" =~ ^[Yy]$ ]]
}

press_enter() {
  echo ""
  echo -e "  ${DIM}Press Enter to return to menu...${RESET}"
  read -r
}

before_after() {
  local before=$1
  local after
  after=$(free_space)
  echo ""
  echo -e "  ${DIM}Before: $before free  →  After: $after free${RESET}"
}

# ---- Option Functions ----

system_info() {
  header
  section "System Information"
  echo ""
  sw_vers
  echo ""
  echo -e "  ${BOLD}CPU:${RESET}     $(sysctl -n machdep.cpu.brand_string 2>/dev/null || echo 'Apple Silicon')"
  echo -e "  ${BOLD}RAM:${RESET}     $(( $(sysctl -n hw.memsize) / 1073741824 )) GB"
  echo -e "  ${BOLD}Disk:${RESET}    $(disk_used) used / $(df -h / | awk 'NR==2 {print $2}') total  ($(free_space) free)"
  echo ""
  section "Installed Dev Tools"
  for cmd in node npm pnpm yarn python3 git aws docker brew; do
    if command -v $cmd &>/dev/null; then
      ver=$($cmd --version 2>/dev/null | head -1)
      success "$cmd  ${DIM}$ver${RESET}"
    else
      warn "$cmd  ${DIM}not installed${RESET}"
    fi
  done
  press_enter
}

disk_report() {
  header
  section "Disk Usage Report"
  BEFORE=$(free_space)
  echo ""
  echo -e "  ${BOLD}Free Space:${RESET} $(free_space)"
  echo ""
  echo -e "  ${BOLD}Top space consumers in home directory:${RESET}"
  echo ""
  du -hd 1 ~ 2>/dev/null | sort -hr | head -15 | while read -r size path; do
    echo -e "  ${CYAN}$size${RESET}  $path"
  done
  echo ""
  section "Key Cache Sizes"
  for dir in \
    "Homebrew Cache:$HOME/Library/Caches/Homebrew" \
    "npm Cache:$HOME/.npm" \
    "pnpm Store:$HOME/Library/pnpm" \
    "~/.cache:$HOME/.cache" \
    "Library/Caches:$HOME/Library/Caches" \
    "Library/Logs:$HOME/Library/Logs" \
    "VS Code:$HOME/Library/Application Support/Code" \
    "Claude:$HOME/Library/Application Support/Claude" \
    "Trash:$HOME/.Trash"; do
    label="${dir%%:*}"
    path="${dir#*:}"
    if [ -d "$path" ]; then
      size=$(du -sh "$path" 2>/dev/null | cut -f1)
      echo -e "  ${CYAN}$size${RESET}  $label"
    fi
  done
  press_enter
}

homebrew_cleanup() {
  header
  section "Homebrew Cleanup"
  BEFORE=$(free_space)
  echo ""
  info "Running: brew cleanup --dry-run"
  brew cleanup --dry-run 2>/dev/null
  echo ""
  if confirm "Proceed with Homebrew cleanup?"; then
    brew cleanup
    brew autoremove
    success "Homebrew cleanup done"
    log "Homebrew cleanup"
    before_after "$BEFORE"
  else
    info "Skipped"
  fi
  press_enter
}

npm_cleanup() {
  header
  section "Node / npm / pnpm / yarn Cleanup"
  BEFORE=$(free_space)
  echo ""
  if command -v npm &>/dev/null; then
    info "npm cache size: $(du -sh ~/.npm 2>/dev/null | cut -f1)"
  fi
  if command -v pnpm &>/dev/null; then
    info "pnpm store size: $(du -sh "$(pnpm store path 2>/dev/null)" 2>/dev/null | cut -f1)"
  fi
  echo ""
  if confirm "Clean npm, pnpm, and yarn caches?"; then
    command -v npm &>/dev/null && npm cache clean --force && success "npm cache cleaned"
    command -v pnpm &>/dev/null && pnpm store prune && success "pnpm store pruned"
    command -v yarn &>/dev/null && yarn cache clean && success "yarn cache cleaned"
    command -v php &>/dev/null && php -r "opcache_reset();" 2>/dev/null && success "PHP opcache cleared"
    command -v composer &>/dev/null && composer clear-cache &>/dev/null && success "Composer cache cleaned"
    log "npm/pnpm/yarn cleanup"
    before_after "$BEFORE"
  else
    info "Skipped"
  fi
  press_enter
}

docker_cleanup() {
  header
  section "Docker Cleanup"
  BEFORE=$(free_space)
  echo ""
  if ! docker info &>/dev/null 2>&1; then
    warn "Docker Desktop is not running. Start it first."
    press_enter
    return
  fi
  echo ""
  docker system df
  echo ""
  if confirm "Run docker system prune -af (removes ALL unused images, containers, networks)?"; then
    docker system prune -af
    docker volume prune -f
    success "Docker cleanup done"
    log "Docker cleanup"
    before_after "$BEFORE"
  else
    info "Skipped"
  fi
  press_enter
}

vscode_cleanup() {
  header
  section "VS Code Cache Cleanup"
  BEFORE=$(free_space)
  echo ""
  VS_CACHE="$HOME/Library/Caches/com.microsoft.VSCode"
  VS_LOGS="$HOME/Library/Application Support/Code/logs"
  info "VS Code cache: $(du -sh "$VS_CACHE" 2>/dev/null | cut -f1)"
  info "VS Code logs:  $(du -sh "$VS_LOGS" 2>/dev/null | cut -f1)"
  echo ""
  if confirm "Clean VS Code cache and logs?"; then
    rm -rf "$VS_CACHE" 2>/dev/null && success "VS Code cache cleaned"
    rm -rf "$VS_LOGS" 2>/dev/null && success "VS Code logs cleaned"
    log "VS Code cleanup"
    before_after "$BEFORE"
  else
    info "Skipped"
  fi
  press_enter
}

system_cache_cleanup() {
  header
  section "System Cache Cleanup (Safe)"
  BEFORE=$(free_space)
  echo ""
  warn "This cleans user-level caches only. System caches are skipped."
  info "Library/Caches: $(du -sh ~/Library/Caches 2>/dev/null | cut -f1)"
  info "Library/Logs:   $(du -sh ~/Library/Logs 2>/dev/null | cut -f1)"
  info "~/.cache:       $(du -sh ~/.cache 2>/dev/null | cut -f1)"
  echo ""
  if confirm "Clean user caches and logs?"; then
    # Clean safe subdirs in ~/Library/Caches (skip Apple-signed ones)
    find ~/Library/Caches -mindepth 1 -maxdepth 1 -type d ! -name "com.apple.*" -exec rm -rf {} + 2>/dev/null
    rm -rf ~/Library/Logs/* 2>/dev/null
    rm -rf ~/.cache/pip 2>/dev/null
    rm -rf ~/.cache/node-gyp 2>/dev/null
    success "User caches cleaned"
    log "System cache cleanup"
    before_after "$BEFORE"
  else
    info "Skipped"
  fi
  press_enter
}

dns_flush() {
  header
  section "Flush DNS Cache"
  echo ""
  info "Flushing DNS..."
  sudo dscacheutil -flushcache
  sudo killall -HUP mDNSResponder
  success "DNS cache flushed"
  log "DNS flush"
  press_enter
}

empty_trash() {
  header
  section "Empty Trash"
  BEFORE=$(free_space)
  echo ""
  info "Trash size: $(du -sh ~/.Trash 2>/dev/null | cut -f1)"
  echo ""
  if confirm "Empty Trash permanently?"; then
    rm -rf ~/.Trash/* 2>/dev/null
    success "Trash emptied"
    log "Trash emptied"
    before_after "$BEFORE"
  else
    info "Skipped"
  fi
  press_enter
}

find_large_files() {
  header
  section "Find Large Files (> 500 MB)"
  echo ""
  info "Scanning home directory... (this may take a moment)"
  echo ""
  find ~ -type f -size +500M 2>/dev/null | while read -r f; do
    size=$(du -sh "$f" 2>/dev/null | cut -f1)
    echo -e "  ${RED}$size${RESET}  $f"
  done
  echo ""
  success "Scan complete"
  press_enter
}

deep_clean() {
  header
  section "Developer Deep Clean"
  BEFORE=$(free_space)
  echo ""
  warn "This runs: Homebrew + npm/pnpm + Docker + VS Code + User Cache + Trash"
  echo ""
  if confirm "Run full deep clean?"; then
    echo ""
    info "Homebrew..."
    brew cleanup &>/dev/null && brew autoremove &>/dev/null && success "Homebrew done"

    info "npm..."
    command -v npm &>/dev/null && npm cache clean --force &>/dev/null && success "npm done"

    info "pnpm..."
    command -v pnpm &>/dev/null && pnpm store prune &>/dev/null && success "pnpm done"

    info "yarn..."
    command -v yarn &>/dev/null && yarn cache clean &>/dev/null && success "yarn done"

    command -v php &>/dev/null && php -r "opcache_reset();" 2>/dev/null && success "PHP opcache cleared"
    command -v composer &>/dev/null && composer clear-cache &>/dev/null && success "Composer cache cleaned"

    info "Docker..."
    if docker info &>/dev/null 2>&1; then
      docker system prune -af &>/dev/null
      docker volume prune -f &>/dev/null
      success "Docker done"
    else
      warn "Docker not running, skipped"
    fi

    info "VS Code cache..."
    rm -rf "$HOME/Library/Caches/com.microsoft.VSCode" 2>/dev/null
    rm -rf "$HOME/Library/Application Support/Code/logs" 2>/dev/null
    success "VS Code done"

    info "User cache..."
    find ~/Library/Caches -mindepth 1 -maxdepth 1 -type d ! -name "com.apple.*" -exec rm -rf {} + 2>/dev/null
    rm -rf ~/Library/Logs/* 2>/dev/null
    rm -rf ~/.cache/pip ~/.cache/node-gyp 2>/dev/null
    success "User cache done"

    info "Trash..."
    rm -rf ~/.Trash/* 2>/dev/null
    success "Trash done"

    info "DNS flush..."
    sudo dscacheutil -flushcache
    sudo killall -HUP mDNSResponder
    success "DNS flushed"

    log "Deep clean"
    before_after "$BEFORE"
  else
    info "Skipped"
  fi
  press_enter
}

update_everything() {
  header
  section "Update Everything"
  echo ""
  if confirm "Run all updates (Homebrew, npm globals, pnpm, AWS CLI)?"; then
    info "Homebrew update..."
    brew update && brew upgrade && success "Homebrew updated"

    info "npm globals..."
    command -v npm &>/dev/null && npm update -g &>/dev/null && success "npm globals updated"

    info "AWS CLI..."
    command -v aws &>/dev/null && brew upgrade awscli &>/dev/null && success "AWS CLI checked"

    log "Update all"
    success "All updates done"
  else
    info "Skipped"
  fi
  press_enter
}

health_report() {
  header
  section "Health Report"
  echo ""
  echo -e "  ${BOLD}Disk:${RESET}         $(disk_used) used, $(free_space) free"
  echo -e "  ${BOLD}Uptime:${RESET}       $(uptime | awk -F'up ' '{print $2}' | awk -F',' '{print $1}')"
  echo ""
  section "Cache Sizes"
  declare -A sizes=(
    ["Homebrew"]="$HOME/Library/Caches/Homebrew"
    ["npm"]="$HOME/.npm"
    ["pnpm"]="$HOME/Library/pnpm"
    ["~/.cache"]="$HOME/.cache"
    ["Library/Caches"]="$HOME/Library/Caches"
    ["VS Code"]="$HOME/Library/Caches/com.microsoft.VSCode"
    ["Trash"]="$HOME/.Trash"
  )
  for label in "Homebrew" "npm" "pnpm" "~/.cache" "Library/Caches" "VS Code" "Trash"; do
    path="${sizes[$label]}"
    if [ -d "$path" ]; then
      size=$(du -sh "$path" 2>/dev/null | cut -f1)
      echo -e "  ${CYAN}$size${RESET}  $label"
    fi
  done
  echo ""
  section "Brew Doctor"
  brew doctor 2>&1 | head -5
  press_enter
}

view_log() {
  header
  section "Cleanup Log"
  echo ""
  if [ -f "$LOG_FILE" ]; then
    tail -30 "$LOG_FILE"
  else
    info "No log entries yet."
  fi
  press_enter
}

# ---- Main Menu ----

main_menu() {
  while true; do
    header
    echo -e "  ${BOLD}Free Space: $(free_space)${RESET}"
    echo ""
    echo -e "  ${BOLD}1.${RESET}  System Information"
    echo -e "  ${BOLD}2.${RESET}  Disk Usage Report"
    echo -e "  ${BOLD}3.${RESET}  Homebrew Cleanup"
    echo -e "  ${BOLD}4.${RESET}  npm / pnpm / yarn Cleanup"
    echo -e "  ${BOLD}5.${RESET}  Docker Cleanup"
    echo -e "  ${BOLD}6.${RESET}  VS Code Cache Cleanup"
    echo -e "  ${BOLD}7.${RESET}  System Cache Cleanup (Safe)"
    echo -e "  ${BOLD}8.${RESET}  Flush DNS Cache"
    echo -e "  ${BOLD}9.${RESET}  Empty Trash"
    echo -e "  ${BOLD}10.${RESET} Find Large Files (> 500 MB)"
    echo -e "  ${BOLD}11.${RESET} Developer Deep Clean (All)"
    echo -e "  ${BOLD}12.${RESET} Update Everything"
    echo -e "  ${BOLD}13.${RESET} Health Report"
    echo -e "  ${BOLD}14.${RESET} View Cleanup Log"
    echo ""
    echo -e "  ${BOLD}0.${RESET}  Exit"
    echo ""
    echo -e "  ${DIM}Choose an option:${RESET} \c"
    read -r choice

    case $choice in
      1) system_info ;;
      2) disk_report ;;
      3) homebrew_cleanup ;;
      4) npm_cleanup ;;
      5) docker_cleanup ;;
      6) vscode_cleanup ;;
      7) system_cache_cleanup ;;
      8) dns_flush ;;
      9) empty_trash ;;
      10) find_large_files ;;
      11) deep_clean ;;
      12) update_everything ;;
      13) health_report ;;
      14) view_log ;;
      0) echo ""; info "Bye!"; echo ""; exit 0 ;;
      *) warn "Invalid option" ;;
    esac
  done
}

main_menu
